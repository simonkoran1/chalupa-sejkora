---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Editor — Chalupa Sejkora" lang="cs">
  <main style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <form id="cms-login-form" style="width: 100%; max-width: 24rem; display: flex; flex-direction: column; gap: 1rem;">
      <h1 style="font-size: 1.5rem; margin: 0 0 .5rem;">Editor</h1>
      <p style="margin: 0; color: #666; font-size: .9rem;">Přihlaste se pro úpravu obsahu.</p>
      <input type="password" name="password" required autocomplete="current-password" placeholder="Heslo"
        class="form-input" style="width: 100%;" />
      <button type="submit" class="button" style="width: 100%;">Přihlásit</button>
      <div id="cms-login-error" style="color: #b00; font-size: .9rem; display: none;"></div>
    </form>
  </main>
</Layout>

<script is:inline>
  document.getElementById('cms-login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const password = new FormData(e.target).get('password');
    const errEl = document.getElementById('cms-login-error');
    errEl.style.display = 'none';
    try {
      const resp = await fetch('/api/cms/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password }),
      });
      if (resp.status === 404) {
        errEl.textContent = 'CMS není nakonfigurováno.';
        errEl.style.display = 'block';
        return;
      }
      if (!resp.ok) {
        errEl.textContent = 'Nesprávné heslo.';
        errEl.style.display = 'block';
        return;
      }
      window.location.href = '/';
    } catch (err) {
      errEl.textContent = 'Chyba připojení.';
      errEl.style.display = 'block';
    }
  });
</script>
