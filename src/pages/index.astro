  { icon: "/images/646e429d659fceed0ce16d0c_trophy.svg", label: "Stolní fotbálek" },
  { icon: "/images/646e427d42ec6866215871f1_flag.svg", label: "Pingpongový stůl" },
  { icon: "/images/646e4177c2e8a5002a538a30_fire.svg", label: "Venkovní gril" },
