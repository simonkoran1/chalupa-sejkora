  { icon: "/images/646e4246a96973549500817c_face-smile.svg", label: "Společenská místnost" },
  { icon: "/images/646e3cb5caf85a6a5230fb25_check-circlegreen.svg", label: "Vybavená kuchyně" },
  { icon: "/images/646e4202e07dba25a81d9d98_heart.svg", label: "Herní koutek pro děti" },
