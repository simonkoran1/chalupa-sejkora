const surroundingsImages = [
  { url: "/images/646e676880c678ba21ea6857_image-crop-200001022.jpeg", caption: "Paseky nad Jizerou", distance: "6,5 KM • 8 MIN. AUTEM" },
  { url: "/images/6476f280b2510bb26a3ef2aa_Rokytnice-nad-Jizerou.jpg", caption: "Rokytnice nad Jizerou", distance: "8,4 KM • 10 MIN. AUTEM" },
  { url: "/images/6485e70de8b0f28bdcb9bf9e_2022-08-14.jpg", caption: "Bozkovské dolomitové jeskyně", distance: "10,1 KM • 13 MIN. AUTEM" },
  { url: "/images/6476f1160a13cdc954617cd8_Stepanka_lookout_tower.jpeg", caption: "Rozhledna Štěpánka", distance: "11,3 KM • 13 MIN. AUTEM" },
  { url: "/images/6476f2a1f6a8eff90695ab36_korenov-jaroslav-moravec-001.jpg", caption: "Kořenov", distance: "12,5 KM • 14 MIN. AUTEM" },
  { url: "/images/6485e76cdcc1f215a87f1b87_udoli-jizery-riegrova-stezka-2022_19_4-094401.jpg", caption: "Přírodní rezervace údolí Jizery", distance: "14 KM • 15 MIN. AUTEM" },
  { url: "/images/6476f3c16421f48719b74beb_rokytnice-jpg.jpg", caption: "Lysá hora", distance: "15,4 KM • 21 MIN. AUTEM" },
  { url: "/images/6485ea447c7f3e612c64a581_harrachov_1.jpg", caption: "Harrachov", distance: "19,9 KM • 22 MIN. AUTEM" },
  { url: "/images/6485e988da5571598646a9bc_osada-jizera---jizerka258.jpg", caption: "Osada Jizerka", distance: "20,2 KM • 24 MIN. AUTEM" },
  { url: "/images/6485ef2bda557159864af456_Tanvaldsky-Spicak-Report-AD-2021-02.jpg", caption: "Bikepark Tanvaldský Špičák", distance: "20,8 KM • 26 MIN. AUTEM" },
  { url: "/images/6485f03fda557159864bcb76_Benecko_pohled_na_Kotel.jpeg", caption: "Benecko", distance: "21,5 KM • 24 MIN. AUTEM" },
  { url: "/images/6485e7c9e17e150882bfdcca_117575200_3190117631066976_7992518370262501705_n.jpg", caption: "Rozhledna Černá Studnice", distance: "24,8 KM • 31 MIN. AUTEM" },
  { url: "/images/646e68e48367888e9da262e4_6297_P1180654-Pramen.jpeg", caption: "Pramen Labe", distance: "34,9 KM • 45 MIN. AUTEM" },
  { url: "/images/6476f1b4b8cad4706f74cbed_sekce_leto_hero_final-min.webp", caption: "Špindlerův Mlýn", distance: "35,7 KM • 36 MIN. AUTEM" },
  { url: "/images/6476f2024de25b2b8b35e38e_prachovske-skaly-panorama.jpg", caption: "Český ráj", distance: "36,4 KM • 44 MIN. AUTEM" },
];

const mapPinIcon = "/images/646e67c221bf1a9b03208e1b_map-pin.svg";
const eyeWhiteIcon = "/images/646e0ccb6876000012814b0d_eyewhite.svg";
const arrowRightIcon = "/images/6470a888c22911c855a58e7f_arrow-right-circle.svg";
---

<Layout title="Ubytování ve Vysokém nad Jizerou – Chalupa Sejkora" lang="cs">
  <div class="page-wrapper" id="uvod">
    <Navbar lang="cs" />

    <main class="main-wrapper">

      <!-- HERO -->
      <header class="section side-flowers-hero">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large no-bottom-padding">
              <div class="header_component">
                <div class="margin-bottom margin-xxlarge">
                  <div class="text-align-center">
                    <div class="max-width-large">
                      <div class="margin-bottom margin-small">
                        <div class="margin-bottom margin-small">
                          <div class="text-note-icon">
                            <div class="text-note">Ubytování ve VYSOKÉM NAD&nbsp;JIZEROU</div>
                          </div>
                        </div>
                        <h1>Venkovská chalupa pro&nbsp;vaši jedinečnou <span class="text-highlight">dovolenou</span></h1>
                      </div>
                      <p class="text-size-medium">Chalupa Sejkora se nachází v&nbsp;půvabném městečku Vysoké nad Jizerou, které je svým umístěním na&nbsp;rozhraní Krkonoš a&nbsp;Jizerských hor ideálním výchozím bodem pro&nbsp;poznávání tohoto malebného kraje.</p>
                      <div class="margin-top margin-medium">
                        <div class="button-group is-center">
                          <a href="#rezervace" class="button">Rezervace</a>
                          <a href="#vybaveni-chalupy" class="button is-secondary">Vybavení</a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Image Slider -->
                <div class="header_image-wrapper">
                  <div class="hp-slider">
                    <div class="hp-slider-mask">
                      {heroImages.map((img, i) => (
                        <div class={`hp-slider-slide${i === 0 ? " active" : ""}`}>
                          <img src={img.src} loading="eager" alt={img.alt} class="header_slider_image" />
                        </div>
                      ))}
                    </div>
                    <div class="hide">
                      {heroImages.map((_, i) => (
                        <button class={`w-slider-dot${i === 0 ? " w-active" : ""}`} aria-label={`Slide ${i + 1}`}></button>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- AMENITIES -->
      <header id="vybaveni-chalupy" class="section">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="flex-center-vertical">
                <div class="margin-bottom margin-large">
                  <div class="text-align-center">
                    <div class="max-width-large">
                      <div class="margin-bottom margin-small">
                        <div class="margin-bottom margin-small">
                          <div class="text-note">vybavení chalupy</div>
                        </div>
                        <div class="margin-bottom margin-small">
                          <h2>Zažijte kombinaci dávné <span class="text-highlight">atmosféry</span> s&nbsp;moderním vybavením</h2>
                        </div>
                        <p class="text-size-medium">Chceme, abyste se u nás cítili lépe než v hotelu, proto klademe důraz na čistotu prostředí a&nbsp;pohodlný spánek každého z našich hostů.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="amenities-grid">
                {amenities.map(a => (
                  <div class="amenities-item">
                    <img src={a.icon} loading="lazy" alt="" class="icon-1x1-small" />
                    <div>{a.label}</div>
                  </div>
                ))}
              </div>

              <!-- FAQ -->
              <div class="grid-additional">
                <div class="flex-center-vertical">
                  <div class="max-width-large">
                    <div class="faq_accordion">
                      <div class="faq_question">
                        <div class="faq_question-left">
                          <img src="/images/646e600d322cc34ef3a5bde7_information-circle.svg" loading="lazy" alt="" class="icon-1x1-xsmall" />
                          <div class="text-size-medium text-weight-bold">Další&nbsp;vybavení a&nbsp;informace</div>
                        </div>
                        <div class="faq_icon">
                          <svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg>
                        </div>
                      </div>
                      <div class="faq_answer">
                        <div class="faq_answer-wrap">
                          <ul class="faq-answer-list">
                            <li>Chalupa disponuje 10 lůžky + 2 plnohodnotnými přistýlkami (pro dospělé) s možností dalšího rozšíření o dětské postýlky.</li>
                            <li>Ložnice 1 – manželská postel, palanda i pro dospělé, rozkládací pohovka (futon Karup)</li>
                            <li>Ložnice 2 – manželská postel, palanda i pro dospělé, pohovka</li>
                            <li>Ložnice 3 – manželská postel, dětská postýlka</li>
                            <li>2 koupelny s toaletami a pračkou – jedna se sprchovým koutem, druhá s vanou</li>
                            <li>Plně vybavená kuchyňská linka: lednice s mrazákem, myčka, indukční varná deska, espresso kávovar, nádobí, příbory a mnoho dalšího.</li>
                            <li>Společenská místnost – klenuté srdce naší chalupy s jídelním stolem s barem, krbovými kamny, smart TV s Netflixem, soundbarem a deskovými hrami.</li>
                            <li>Vyhrazené místo na uložení lyží s vyhřívanými držáky na boty.</li>
                          </ul>
                          <div class="divider"></div>
                          <ul class="faq-answer-list">
                            <li>Odpočinková stodola s finskou saunou pro 4 osoby, pingpongem, stolním fotbálkem a venkovním posezením s grilem.</li>
                            <li>Celou oplocenou zahradu budete mít k dispozici pouze pro sebe. Na zahradě se nachází dětské hřiště se skluzavkou, houpačkami a pískovištěm, ohniště a prostor pro hry.</li>
                            <li>Parkování až pro 3 automobily přímo u chalupy.</li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    <div class="faq_accordion">
                      <div class="faq_question">
                        <div class="faq_question-left">
                          <img src={mapPinIcon} loading="lazy" alt="" class="icon-1x1-xsmall" />
                          <div class="text-size-medium text-weight-bold">Služby v&nbsp;okolí chalupy</div>
                        </div>
                        <div class="faq_icon">
                          <svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg>
                        </div>
                      </div>
                      <div class="faq_answer">
                        <div class="faq_answer-wrap">
                          <ul class="faq-answer-list">
                            <li>Potraviny COOP – 150 metrů</li>
                            <li>Pekárna Krakonošovo pekařství – 200 metrů</li>
                            <li>Cukrárna U Bachtíků – 130 metrů</li>
                            <li>Restaurace U Medvěda – 170 metrů</li>
                            <li>Restaurace Crazy – 90 metrů</li>
                            <li>Park básníků – 190 metrů</li>
                            <li>Divadlo Krakonoš – 160 metrů</li>
                            <li>Lékárna – 80 metrů</li>
                            <li>Ski areál Šachty – 900 metrů</li>
                          </ul>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- ABOUT -->
      <section id="o-chalupe" class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large no-bottom-padding">
              <div class="margin-bottom margin-xxlarge">
                <div class="max-width-large">
                  <div class="margin-bottom margin-small">
                    <div class="margin-bottom margin-small">
                      <div class="text-note">o&nbsp;chalupě</div>
                    </div>
                    <div class="max-width-medium">
                      <h2>Klid a <span class="text-highlight">relaxace</span> v&nbsp;srdci Vysokého nad&nbsp;Jizerou</h2>
                    </div>
                  </div>
                  <div class="margin-bottom margin-medium">
                    <p class="text-size-medium">Naše chalupa, jejíž historie sahá k roku 1800, vám nabízí ubytování až pro 12 osob. Chalupa disponuje 3 ložnicemi, 2 koupelnami, plně vybavenou kuchyní, prostornou společenskou místností s krbovými kamny a odpočinkovou stodolou.<br /><br />Parkování až pro 3 automobily přímo u chalupy, další vozy mohou zdarma parkovat na náměstí vzdáleném 100 metrů.</p>
                  </div>
                </div>
              </div>

              <!-- Gallery -->
              <div class="gallery_component">
                <div class="gallery_slider" id="gallery-main">
                  <div class="gallery_mask">
                    {galleryImages.map((img, i) => (
                      <div class="gallery_slide">
                        <div class="slide-overlay"></div>
                        <a href="#" class="gallery_lightbox-link" data-url={img.url} data-caption={img.caption}>
                          <div class="gallery_image-wrapper">
                            <img src={img.url} alt={img.caption} class="gallery_image" />
                            <div class="gallery-hover-overlay">
                              <img src={eyeWhiteIcon} loading="lazy" alt="" class="icon-1x1-small" />
                            </div>
                          </div>
                        </a>
                        <div class="gallery_text-wrap">
                          <div class="margin-bottom margin-tiny"><div class="text-note">chalupa</div></div>
                          <div class="max-width-small"><div>{img.label}</div></div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="gallery21_arrow is-left" role="button" aria-label="Previous slide">
                    <div class="gallery21_arrow-icon"><svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.31066 8.75001L9.03033 14.4697L7.96967 15.5303L0.439339 8.00001L7.96967 0.469676L9.03033 1.53034L3.31066 7.25001L15.5 7.25L15.5 8.75L3.31066 8.75001Z" fill="currentColor"></path></svg></div>
                  </div>
                  <div class="gallery21_arrow" role="button" aria-label="Next slide">
                    <div class="gallery21_arrow-icon"><svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.6893 7.25L6.96967 1.53033L8.03033 0.469666L15.5607 8L8.03033 15.5303L6.96967 14.4697L12.6893 8.75H0.5V7.25H12.6893Z" fill="currentColor"></path></svg></div>
                  </div>
                  <div class="gallery_slide-nav">
                    {galleryImages.map((_, i) => (
                      <button class={`w-slider-dot${i === 0 ? " w-active" : ""}`} aria-label={`Slide ${i + 1}`}></button>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAMILIES -->
      <section class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="layout_component">
                <div class="layout_content">
                  <div class="margin-bottom margin-small"><h3>Myslíme na <span class="text-highlight">rodiny</span> s&nbsp;dětmi</h3></div>
                  <div class="margin-bottom margin-small"><img src="/images/647321a78126600a5a05bde0_flower.svg" loading="lazy" alt="" class="flower-divider" /></div>
                  <div class="margin-bottom margin-small"><p class="text-size-medium">Celá chalupa je zařízena pro příjemný pobyt rodin s dětmi, aby se stala vaším výborným zázemím pro bezstarostnou dovolenou. K dispozici budete mít přebalovací pult, deskové hry, knížky, sportovní vybavení a mnoho dalšího.</p></div>
                  <div class="margin-top margin-medium">
                    <div class="button-group"><a href="#rezervace" class="button">Rezervace</a></div>
                  </div>
                </div>
                <div class="layout_image-wrapper">
                  <img src="/images/64fec541385f1e55d5bdf3e7_Sejkora_obyvaci_pokoj_1_Large.jpeg" loading="lazy" alt="Obývací pokoj" class="layout_image" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- BARN -->
      <section class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="layout_component">
              <div class="layout_image-wrapper">
                <img src="/images/64fecc2a2994b2723a1efd2f_Sejkora_posezeni_ve_stodole_1_Large.jpeg" loading="lazy" alt="Stodola" class="layout_image" />
              </div>
              <div class="layout_content">
                <div class="margin-bottom margin-small"><div class="max-width-small"><h3><span class="text-highlight">Unikátní</span> kombinace odpočinku a&nbsp;venkovního vyžití</h3></div></div>
                <div class="margin-bottom margin-small"><img src="/images/647321a78126600a5a05bde0_flower.svg" loading="lazy" alt="" class="flower-divider" /></div>
                <div class="margin-bottom margin-small"><p class="text-size-medium">Vychutnejte si dokonalý relax v naší odpočinkové stodole s finskou saunou, venkovním posezením, grilem a zábavou u ping-pongového stolu a fotbálku.</p></div>
                <div class="margin-top margin-medium">
                  <div class="button-group"><a href="#rezervace" class="button">Rezervace</a></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SURROUNDINGS -->
      <section id="okoli" class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="margin-bottom margin-xxlarge">
                <div class="max-width-large">
                  <div class="margin-bottom margin-small">
                    <div class="margin-bottom margin-small"><div class="text-note">Okolí A&nbsp;tipy na výlet</div></div>
                    <h2>Prožijte <span class="text-highlight">kouzlo</span> českého horského&nbsp;ráje</h2>
                  </div>
                  <p class="text-size-medium">Hned za chalupou na vás čekají výhledy na Krkonoše, Jizerské hory, Kozákov či Bezděz. V pěší dostupnosti lyžařské vleky, Park básníků, několik restaurací, divadlo Krakonoš a výborná pekárna.</p>
                </div>
              </div>

              <div class="gallery_component">
                <div class="gallery_slider" id="gallery-surroundings">
                  <div class="gallery_mask">
                    {surroundingsImages.map((img, i) => (
                      <div class="gallery_slide">
                        <div class="slide-overlay"></div>
                        <a href="#" class="gallery_lightbox-link" data-url={img.url} data-caption={img.caption}>
                          <div class="gallery_image-wrapper">
                            <img src={img.url} alt={img.caption} class="gallery_image" />
                            <div class="gallery-hover-overlay">
                              <img src={eyeWhiteIcon} loading="lazy" alt="" class="icon-1x1-small" />
                            </div>
                          </div>
                        </a>
                        <div class="gallery_text-wrap">
                          <div class="margin-bottom margin-tiny"><div class="text-note">{img.distance}</div></div>
                          <div class="icon-tag">
                            <img src={mapPinIcon} loading="lazy" alt="" class="icon-1x1-xxsmall" />
                            <div>{img.caption}</div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="gallery21_arrow is-left" role="button" aria-label="Previous">
                    <div class="gallery21_arrow-icon"><svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.31066 8.75001L9.03033 14.4697L7.96967 15.5303L0.439339 8.00001L7.96967 0.469676L9.03033 1.53034L3.31066 7.25001L15.5 7.25L15.5 8.75L3.31066 8.75001Z" fill="currentColor"></path></svg></div>
                  </div>
                  <div class="gallery21_arrow" role="button" aria-label="Next">
                    <div class="gallery21_arrow-icon"><svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.6893 7.25L6.96967 1.53033L8.03033 0.469666L15.5607 8L8.03033 15.5303L6.96967 14.4697L12.6893 8.75H0.5V7.25H12.6893Z" fill="currentColor"></path></svg></div>
                  </div>
                  <div class="gallery_slide-nav">
                    {surroundingsImages.map((_, i) => (
                      <button class={`w-slider-dot${i === 0 ? " w-active" : ""}`} aria-label={`Slide ${i + 1}`}></button>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- PRICING -->
      <section id="cenik" class="section">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large no-bottom-padding">
              <div class="margin-bottom margin-xxlarge">
                <div class="text-align-center">
                  <div class="max-width-large align-center">
                    <div class="margin-bottom margin-small">
                      <div class="margin-bottom margin-small"><div class="text-note">ceník</div></div>
                      <h2>Rozumné ceny pro vaši snovou&nbsp;<span class="text-highlight">dovolenou</span></h2>
                    </div>
                    <p class="text-size-medium">V&nbsp;závislosti na roční době je možné chalupu rezervovat na odlišné minimum nocí.</p>
                  </div>
                </div>
              </div>

              <div class="pricing_components">
                <div class="pricing_plan" style="grid-column: span 2">
                  <div class="pricing18_content">
                    <div class="pricing_content-top">
                      <div class="pricing-name-wrap"><div class="heading-style-h5">Vedlejší sezóna</div><div class="small-tag big">Min. 2 noci</div></div>
                      <div class="divider"></div>
                      <div class="tags-wrapper"><div class="small-tag">Březen</div><div class="small-tag">Duben</div><div class="small-tag">Říjen</div><div class="small-tag">Listopad</div></div>
                      <div class="divider"></div>
                      <div class="pricing_feature-list">
                        <div class="pricing_feature"><div class="text-weight-bold">2 noci</div><div><span class="text-weight-bold">5.500,- Kč</span> / noc</div></div>
                        <div class="pricing_feature"><div class="text-weight-bold">3–4 noci</div><div><span class="text-weight-bold">4.500,- Kč</span> / noc</div></div>
                        <div class="pricing_feature"><div class="text-weight-bold">5+ nocí</div><div><span class="text-weight-bold">4.000,- Kč</span> / noc</div></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="pricing_plan" style="grid-column: span 2">
                  <div class="pricing18_content">
                    <div class="pricing_content-top">
                      <div class="pricing-name-wrap"><div class="heading-style-h5">Střední sezóna</div><div class="small-tag big">Min. 2 noci</div></div>
                      <div class="divider"></div>
                      <div class="tags-wrapper"><div class="small-tag">Květen</div><div class="small-tag">Červen</div><div class="small-tag">Září</div><div class="small-tag">Prosinec</div></div>
                      <div class="divider"></div>
                      <div class="pricing_feature-list">
                        <div class="pricing_feature"><div class="text-weight-bold">2 noci</div><div><span class="text-weight-bold">6.000,- Kč</span> / noc</div></div>
                        <div class="pricing_feature"><div class="text-weight-bold">3–4 noci</div><div><span class="text-weight-bold">5.000,- Kč</span> / noc</div></div>
                        <div class="pricing_feature"><div class="text-weight-bold">5+ nocí</div><div><span class="text-weight-bold">4.000,- Kč</span> / noc</div></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="pricing_plan" style="grid-column: span 2">
                  <div class="pricing18_content">
                    <div class="pricing_content-top">
                      <div class="pricing-name-wrap"><div class="heading-style-h5">Hlavní sezóna</div><div class="small-tag big">Sobota–Sobota</div></div>
                      <div class="divider"></div>
                      <div class="tags-wrapper"><div class="small-tag">Leden</div><div class="small-tag">Únor</div><div class="small-tag">Červenec</div><div class="small-tag">Srpen</div></div>
                      <div class="divider"></div>
                      <div class="pricing_feature-list">
                        <div class="pricing_feature"><div class="text-weight-bold">Léto / Zima</div><div><span class="text-weight-bold">5.000,- Kč</span> / noc</div></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid-additional">
                <div class="flex-center-vertical">
                  <div class="max-width-large">
                    <div class="faq_accordion">
                      <div class="faq_question">
                        <div class="faq_question-left">
                          <img src="/images/646e3cb5caf85a6a5230fb25_check-circlegreen.svg" loading="lazy" alt="" class="icon-1x1-xsmall" />
                          <div class="text-size-medium text-weight-bold">Co ceny zahrnují</div>
                        </div>
                        <div class="faq_icon"><svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg></div>
                      </div>
                      <div class="faq_answer">
                        <div class="faq_answer-wrap">
                          <ul class="faq-answer-list">
                            <li>Ceny platí do počtu 8 ubytovaných. Od 9. hosta se připlácí 200,– Kč / noc / osoba.</li>
                            <li>Pronájem celé chalupy vč. vybavení a rychlého připojení k internetu</li>
                            <li>Ložní prádlo a ručníky pro všechny hosty</li>
                            <li>Spotřeba elektřiny 100 kWh / noc</li>
                            <li>Základy v kuchyni (sůl, koření, čaj, káva)</li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    <div class="faq_accordion">
                      <div class="faq_question">
                        <div class="faq_question-left">
                          <img src="/images/647332ad89a246e55eaab85a_x-circle.svg" loading="lazy" alt="" class="icon-1x1-xsmall" />
                          <div class="text-size-medium text-weight-bold">Co ceny nezahrnují</div>
                        </div>
                        <div class="faq_icon"><svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg></div>
                      </div>
                      <div class="faq_answer">
                        <div class="faq_answer-wrap">
                          <ul class="faq-answer-list">
                            <li>Místní poplatek obci – 18,- Kč / dospělý / noc</li>
                            <li>Závěrečný úklid 1.500,– Kč</li>
                            <li>Spotřeba elektřiny za saunou</li>
                            <li>Spotřeba elektřiny nad 100 kWh / noc</li>
                            <li>Pejsek po předchozí domluvě – 200,- Kč / noc</li>
                            <li>Vratná kauce 5.000,- Kč (vybrána při příjezdu v hotovosti)</li>
