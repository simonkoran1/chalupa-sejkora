      <!-- RESERVATION -->
      <section id="rezervace" class="section side-flowers">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="margin-bottom margin-large">
                <div class="text-align-center">
                  <div class="max-width-large align-center">
                    <div class="margin-bottom margin-small">
                      <div class="margin-bottom margin-small"><div class="text-note">Rezervace</div></div>
                      <h2>Rezervujte si <span class="text-highlight">svůj</span> termín</h2>
                    </div>
                    <p class="text-size-medium">V&nbsp;případě nejasností nás kontaktujte na <a href="mailto:ahoj@chalupasejkora.cz" class="text-style-link">ahoj@chalupasejkora.cz</a>.<br />Rezervaci potvrdíme nejpozději do&nbsp;24 hodin.</p>
                  </div>
                </div>
              </div>

              <div class="calendar-wrapper">
                <div class="w-form">
                  <form id="wf-form-Rezerva-n-formul" class="form-wrapper">
                    <input type="hidden" name="access_key" value="9763ef18-f282-4f78-a9ba-d96df5fe00e4" />
                    <input type="hidden" name="subject" value="Nová rezervace – Chalupa Sejkora" />
                    <input type="hidden" name="from_name" value="Chalupa Sejkora" />
                    <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />
                    <div class="reservation-date-wrap">
                      <label class="field-label">Kalendář obsazenosti</label>
                      <div class="calendar-margin">
                        <div class="faq_accordion outlined">
                          <div class="faq_question in-form">
                            <div class="faq_question-left">
                              <img alt="" loading="lazy" src="/images/6473783f8126600a5a41bf4b_eye.svg" class="icon-1x1-xsmall" />
                              <div>Zobrazit volné termíny</div>
                            </div>
                            <div class="faq_icon"><svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg></div>
                          </div>
                          <div class="faq_answer">
                            <div class="faq_answer-wrap is-relative">
                              <div style="position: relative;">
                                <iframe src="https://obsazenost.e-chalupy.cz/kalendar.php?id=10684&pocetMesicu=12&velikost=3&legenda=ne&jazyk=cz&fontFamily=Source%20Sans%20Pro" height="460px" width="100%" frameborder="0" style="width:100%;"></iframe>
                                <div class="empty-overlay"></div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                      <label for="check-in" class="field-label">Termín pobytu</label>
                      <div class="date-picker-inputs">
                        <input class="flatpickr-input" name="Datum-prijezdu" placeholder="Datum příjezdu" type="text" id="check-in" autocomplete="off" />
                        <img src={arrowRightIcon} alt="" class="dates-icon" />
                        <input class="flatpickr-input" name="Datum-odjezdu" placeholder="Datum odjezdu" type="text" id="check-out" autocomplete="off" />
                      </div>
                    </div>

                    <div>
                      <label for="Name" class="field-label">Jméno</label>
                      <input class="form-input" name="Jmeno" placeholder="Vaše jméno" type="text" id="Name" required />
                    </div>
                    <div>
                      <label for="Email" class="field-label">E-mail</label>
                      <input class="form-input" name="Email" placeholder="jmeno@email.cz" type="email" id="Email" required />
                    </div>
                    <div>
                      <label for="Phone" class="field-label">Telefon</label>
                      <input class="form-input" name="Telefon" placeholder="+420" type="tel" id="Phone" required />
                    </div>
                    <div>
                      <label for="Notes" class="field-label">Poznámka</label>
                      <textarea id="Notes" name="Poznamka" placeholder="Místo pro vaši poznámku nebo přání" class="form-input is-text-area"></textarea>
                    </div>
                    <button type="submit" class="button">Odeslat</button>
                  </form>

                  <div class="success-message">
                    <div class="success-message-inner">
                      <img src="/images/646e3cb5caf85a6a5230fb25_check-circlegreen.svg" loading="lazy" alt="" class="icon-1x1-small" />
                      <div>Děkujeme! Rezervaci potvrdíme nejpozději do&nbsp;24&nbsp;hodin.</div>
                    </div>
                  </div>
                  <div class="w-form-fail">
                    <div>Něco se pokazilo. Zkuste to prosím znovu nebo nás kontaktujte přímo.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

    </main>

    <Footer lang="cs" />
  </div>
</Layout>
