  { url: "/images/6502eee83e4b0972276210f7_AAA_pohled_na_dum_2_Large.jpeg", caption: "Pohled na chalupu", label: "Pohled na chalupu" },
  { url: "/images/64fecd68d795d0489d94adaf_Sejkora_vchod_Large.jpeg", caption: "Vchod", label: "Vchod" },
  { url: "/images/64fec541385f1e55d5bdf3e7_Sejkora_obyvaci_pokoj_1_Large.jpeg", caption: "Obývací pokoj", label: "Společenská místnost" },
  { url: "/images/64fec5c2385f1e55d5be7bf0_Sejkora_obyvaci_pokoj_2_Large.jpeg", caption: "Obývací pokoj", label: "Obývací pokoj" },
  { url: "/images/64fec62c880af21199abfd0f_Sejkora_loznice_1_1_Large.jpeg", caption: "Ložnice 1", label: "Ložnice 1" },
  { url: "/images/64fec68310ef6fb92a3d3e26_Sejkora_loznice_1_4_Large.jpeg", caption: "Ložnice 1", label: "Ložnice 1" },
  { url: "/images/6502b54d3ed0ae8b6d6876d2_AAA_loznice_2_1_Large.jpeg", caption: "Ložnice 2", label: "Ložnice 2" },
  { url: "/images/64fec740625c155c18475d8e_Sejkora_loznice_2_2_Large.jpeg", caption: "Ložnice 2", label: "Ložnice 2" },
  { url: "/images/6502b4da93b1197f48ba5851_AAA_loznice_3_1_Large.jpeg", caption: "Ložnice 3", label: "Ložnice 3" },
  { url: "/images/6502b4f8bada5953b9eb0c22_AAA_loznice_3_2_Large.jpeg", caption: "Ložnice 3", label: "Ložnice 3" },
  { url: "/images/64fecaa67a1b0d48c9176f7b_Sejkora_kuchyne_1_Large.jpeg", caption: "Kuchyně", label: "Kuchyně" },
  { url: "/images/64fecaca9f7f964880182ab1_Sejkora_kuchyne_2_Large.jpeg", caption: "Kuchyně", label: "Kuchyně" },
  { url: "/images/64fecafd126548ca6e8921ec_Sejkora_koupelna_2_Large.jpeg", caption: "Koupelna 1", label: "Koupelna 1" },
  { url: "/images/64fecb17b78725a05b18c774_Sejkora_koupelna_2_1_Large.jpeg", caption: "Koupelna 1", label: "Koupelna 1" },
  { url: "/images/64fecb3aaef6acf8a9ece446_Sejkora_koupelna_1_Large.jpeg", caption: "Koupelna 2", label: "Koupelna 2" },
  { url: "/images/64fecb9ee214f2e762e44a71_Sejkora_detske_hriste_s_piskovistem_1_Large.jpeg", caption: "Dětské hřiště", label: "Dětské hřiště" },
  { url: "/images/64fecbbf71b5f82b71dd7f12_Sejkora_detske_hriste_s_piskovistem_2_Large.jpeg", caption: "Dětské hřiště", label: "Dětské hřiště" },
  { url: "/images/6502b5e1f91f4d27cd395c7b_AAA_zahrada_3_Large.jpeg", caption: "Zahrada", label: "Zahrada" },
  { url: "/images/64fecc2a2994b2723a1efd2f_Sejkora_posezeni_ve_stodole_1_Large.jpeg", caption: "Posezení ve stodole", label: "Posezení ve stodole" },
  { url: "/images/64fecc4ef21d29c63f1f4590_Sejkora_herni_stodola_Large.jpeg", caption: "Herní stodola", label: "Herní stodola" },
  { url: "/images/64fecc91d2ee83c0e2f02c57_Sejkora_finska_sauna_Large.jpeg", caption: "Finská sauna", label: "Finská sauna" },
  { url: "/images/64fecccd16afe625341ca23a_Sejkora_kolarna_lyzarna_1_Large.jpeg", caption: "Kolárna & Lyžárna", label: "Kolárna & Lyžárna" },
  { url: "/images/6502f482b91776de6f7d7c56_sejkora-pudorys.jpg", caption: "Půdorys", label: "Půdorys" },
