---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Contact – Chalupa Sejkora" lang="en">
  <div class="page-wrapper">
    <Navbar lang="en" currentPath="/en/contact" />

    <main class="main-wrapper">
      <header class="section side-flowers">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="header_component">
                <div class="text-align-center">
                  <div class="max-width-large">
                    <div class="margin-bottom margin-small">
                      <div class="margin-bottom margin-small">
                        <div class="text-note-icon"><div class="text-note">Contact</div></div>
                      </div>
                      <h1>How can we <span class="text-highlight">help</span> you?</h1>
                    </div>
                    <div>
                      <span class="text-weight-bold text-size-medium">Address<br /></span>
                      Vysoké nad Jizerou 50,<br />
                      512 11 Vysoké nad Jizerou<br />
                      Czech Republic<br /><br />
                      <span class="text-weight-bold text-size-medium">Contact<br /></span>
                      <a href="tel:+420777356678" class="text-style-link">+420 777 356 678<br /></a>
                      <a href="mailto:ahoj@chalupasejkora.cz" class="text-style-link">ahoj@chalupasejkora.cz</a><br /><br />
                      <span class="text-weight-bold text-size-medium">Operator<br /></span>
                      KOJA invest, s.r.o.<br />
                      ID: 076 07 571 • VAT: CZ07607571<br />
                      Plzákova 1139/6, 197 00 Prague 9 – Kbely
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <section class="section background-color-white">
        <iframe
          style="border:none; display:block; width:100%;"
          src="https://frame.mapy.cz/s/gatosucumu"
          width="100%"
          height="600"
          frameborder="0"
          title="Map"
        ></iframe>
      </section>
    </main>

    <Footer lang="en" />
  </div>
</Layout>
