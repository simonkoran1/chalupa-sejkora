  { url: "/images/6476f2a1f6a8eff90695ab36_korenov-jaroslav-moravec-001.webp", caption: "Kořenov", distance: "12.5 KM • 14 MIN. BY CAR" },
  { url: "/images/6485e76cdcc1f215a87f1b87_udoli-jizery-riegrova-stezka-2022_19_4-094401.webp", caption: "Jizera Valley Nature Reserve", distance: "14 KM • 15 MIN. BY CAR" },
  { url: "/images/6476f3c16421f48719b74beb_rokytnice-jpg.webp", caption: "Lysá hora", distance: "15.4 KM • 21 MIN. BY CAR" },
  { url: "/images/6485ea447c7f3e612c64a581_harrachov_1.webp", caption: "Harrachov", distance: "19.9 KM • 22 MIN. BY CAR" },
  { url: "/images/6485e988da5571598646a9bc_osada-jizera---jizerka258.webp", caption: "Jizerka Village", distance: "20.2 KM • 24 MIN. BY CAR" },
  { url: "/images/6485ef2bda557159864af456_Tanvaldsky-Spicak-Report-AD-2021-02.webp", caption: "Tanvaldský Špičák Bike Park", distance: "20.8 KM • 26 MIN. BY CAR" },
  { url: "/images/6485f03fda557159864bcb76_Benecko_pohled_na_Kotel.webp", caption: "Benecko", distance: "21.5 KM • 24 MIN. BY CAR" },
  { url: "/images/6485e7c9e17e150882bfdcca_117575200_3190117631066976_7992518370262501705_n.webp", caption: "Černá Studnice Lookout", distance: "24.8 KM • 31 MIN. BY CAR" },
  { url: "/images/646e68e48367888e9da262e4_6297_P1180654-Pramen.webp", caption: "Source of the Elbe", distance: "34.9 KM • 45 MIN. BY CAR" },
  { url: "/images/6476f1b4b8cad4706f74cbed_sekce_leto_hero_final-min.webp", caption: "Špindlerův Mlýn", distance: "35.7 KM • 36 MIN. BY CAR" },
  { url: "/images/6476f2024de25b2b8b35e38e_prachovske-skaly-panorama.webp", caption: "Bohemian Paradise", distance: "36.4 KM • 44 MIN. BY CAR" },
];

const mapPinIcon = "/images/646e67c221bf1a9b03208e1b_map-pin.svg";
const eyeWhiteIcon = "/images/646e0ccb6876000012814b0d_eyewhite.svg";
const arrowRightIcon = "/images/6470a888c22911c855a58e7f_arrow-right-circle.svg";
---

<Layout
  title="Cottage accommodation in Vysoké nad Jizerou – Chalupa Sejkora"
  description="A rural cottage for your unique holiday in Vysoké nad Jizerou — a charming mountain town on the border of the Krkonoše and Jizerské hory ranges, an ideal base for exploring this picturesque corner of Bohemia."
  lang="en"
  canonicalPath="/en/"
  alternateUrl="/"
>
  <div class="page-wrapper" id="top">
    <Navbar lang="en" />

    <main class="main-wrapper">

      <!-- HERO -->
      <header class="section side-flowers-hero">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large no-bottom-padding">
              <div class="header_component">
                <div class="margin-bottom margin-xxlarge">
                  <div class="text-align-center">
                    <div class="max-width-large">
                      <div class="margin-bottom margin-small">
                        <div class="margin-bottom margin-small">
                          <div class="text-note-icon">
                            <div class="text-note">Accommodation in VYSOKÉ NAD&nbsp;JIZEROU</div>
                          </div>
                        </div>
                        <h1>A country cottage for your unique <span class="text-highlight">holiday</span></h1>
                      </div>
                      <p class="text-size-medium">Chalupa Sejkora is located in the charming town of Vysoké nad Jizerou, perfectly situated on the border of the Krkonoše and Jizerské hory mountain ranges — an ideal base for exploring this beautiful region.</p>
                      <div class="margin-top margin-medium">
                        <div class="button-group is-center">
                          <a href="#reservation" class="button">Book now</a>
                          <a href="#amenities" class="button is-secondary">Amenities</a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Image Slider -->
                <div class="header_image-wrapper">
                  <div class="hp-slider">
                    <div class="hp-slider-mask">
                      {heroImages.map((img, i) => (
                        <div class={`hp-slider-slide${i === 0 ? " active" : ""}`}>
                          <img src={img.src} loading="eager" alt={img.alt} class="header_slider_image" />
                        </div>
                      ))}
                    </div>
                    <div class="hide">
                      {heroImages.map((_, i) => (
                        <button class={`w-slider-dot${i === 0 ? " w-active" : ""}`} aria-label={`Slide ${i + 1}`}></button>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- AMENITIES -->
      <header id="amenities" class="section">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="flex-center-vertical">
                <div class="margin-bottom margin-large">
                  <div class="text-align-center">
                    <div class="max-width-large">
                      <div class="margin-bottom margin-small">
                        <div class="margin-bottom margin-small">
                          <div class="text-note">cottage amenities</div>
                        </div>
                        <div class="margin-bottom margin-small">
                          <h2>Experience the blend of historic <span class="text-highlight">charm</span> and modern comfort</h2>
                        </div>
                        <p class="text-size-medium">We want you to feel better here than in a hotel — we place great emphasis on cleanliness and a comfortable sleep for every guest.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="amenities-grid">
                {amenities.map(a => (
                  <div class="amenities-item">
                    <img src={a.icon} loading="lazy" alt="" class="icon-1x1-small" />
                    <div>{a.label}</div>
                  </div>
                ))}
              </div>

              <!-- FAQ -->
              <div class="grid-additional">
                <div class="flex-center-vertical">
                  <div class="max-width-large">
                    <div class="faq_accordion">
                      <div class="faq_question">
                        <div class="faq_question-left">
                          <img src="/images/646e600d322cc34ef3a5bde7_information-circle.svg" loading="lazy" alt="" class="icon-1x1-xsmall" />
                          <div class="text-size-medium text-weight-bold">More amenities &amp; information</div>
                        </div>
                        <div class="faq_icon">
                          <svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg>
                        </div>
                      </div>
                      <div class="faq_answer">
                        <div class="faq_answer-wrap">
                          <ul class="faq-answer-list">
                            <li>The cottage has 10 beds + 2 full-size extra beds (for adults), with the option of adding children's cots.</li>
                            <li>Bedroom 1 – double bed, bunk bed (adult-size), fold-out sofa (Karup futon)</li>
                            <li>Bedroom 2 – double bed, bunk bed (adult-size), sofa</li>
                            <li>Bedroom 3 – double bed, children's cot</li>
                            <li>2 bathrooms with toilets and washing machine – one with shower, one with bathtub</li>
                            <li>Fully equipped kitchen: fridge-freezer, dishwasher, induction hob, espresso machine, crockery, cutlery and much more.</li>
                            <li>Common room – the vaulted heart of the cottage with a dining table and bar, fireplace stove, smart TV with Netflix, soundbar, and board games.</li>
                            <li>Dedicated ski storage with heated boot holders.</li>
                          </ul>
                          <div class="divider"></div>
                          <ul class="faq-answer-list">
                            <li>Relaxation barn with a Finnish sauna for 4 people, ping-pong, table football, and an outdoor seating area with BBQ grill.</li>
                            <li>The entire enclosed garden is exclusively yours. It features a children's playground with a slide, swings and sandpit, a fire pit, and space for outdoor games.</li>
                            <li>Parking for up to 3 cars directly at the cottage.</li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    <div class="faq_accordion">
                      <div class="faq_question">
                        <div class="faq_question-left">
                          <img src={mapPinIcon} loading="lazy" alt="" class="icon-1x1-xsmall" />
                          <div class="text-size-medium text-weight-bold">Nearby services</div>
                        </div>
                        <div class="faq_icon">
                          <svg width="100%" height="100%" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M16.5303 20.8839C16.2374 21.1768 15.7626 21.1768 15.4697 20.8839L7.82318 13.2374C7.53029 12.9445 7.53029 12.4697 7.82318 12.1768L8.17674 11.8232C8.46963 11.5303 8.9445 11.5303 9.2374 11.8232L16 18.5858L22.7626 11.8232C23.0555 11.5303 23.5303 11.5303 23.8232 11.8232L24.1768 12.1768C24.4697 12.4697 24.4697 12.9445 24.1768 13.2374L16.5303 20.8839Z" fill="currentColor"></path></svg>
                        </div>
                      </div>
                      <div class="faq_answer">
                        <div class="faq_answer-wrap">
                          <ul class="faq-answer-list">
                            <li>COOP grocery store – 150 m</li>
                            <li>Krakonošovo pekařství bakery – 200 m</li>
                            <li>Cukrárna U Bachtíků patisserie – 130 m</li>
                            <li>U Medvěda restaurant – 170 m</li>
                            <li>Crazy restaurant – 90 m</li>
                            <li>Poets' Park – 190 m</li>
                            <li>Krakonoš Theatre – 160 m</li>
                            <li>Pharmacy – 80 m</li>
                            <li>Šachty ski area – 900 m</li>
                          </ul>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- ABOUT -->
      <section id="about" class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large no-bottom-padding">
              <div class="margin-bottom margin-xxlarge">
                <div class="max-width-large">
                  <div class="margin-bottom margin-small">
                    <div class="margin-bottom margin-small">
                      <div class="text-note">about the cottage</div>
                    </div>
                    <div class="max-width-medium">
                      <h2>Peace and <span class="text-highlight">relaxation</span> in the heart of Vysoké nad&nbsp;Jizerou</h2>
                    </div>
                  </div>
                  <div class="margin-bottom margin-medium">
                    <p class="text-size-medium">Our cottage, whose history dates back to 1800, offers accommodation for up to 12 people. It features 3 bedrooms, 2 bathrooms, a fully equipped kitchen, a spacious common room with a fireplace stove, and a relaxation barn.<br /><br />Parking for up to 3 cars directly at the cottage; additional vehicles can park for free in the square 100 metres away.</p>
                  </div>
                </div>
              </div>

              <!-- Gallery -->
              <div class="gallery_component">
                <div class="gallery_slider swiper" id="gallery-main">
                  <div class="gallery_mask swiper-wrapper">
                    {galleryImages.map((img) => (
                      <div class="gallery_slide swiper-slide">
                        <a href="#" class="gallery_lightbox-link" data-url={img.url} data-caption={img.caption}>
                          <div class="gallery_image-wrapper">
                            <img src={img.url} alt={img.caption} class="gallery_image" />
                            <div class="gallery-hover-overlay">
                              <img src={eyeWhiteIcon} loading="lazy" alt="" class="icon-1x1-small" />
                            </div>
                          </div>
                        </a>
                        <div class="gallery_text-wrap">
                          <div class="margin-bottom margin-tiny"><div class="text-note">cottage</div></div>
                          <div class="max-width-small"><div>{img.label}</div></div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="gallery21_arrow is-left swiper-button-prev" aria-label="Previous slide">
                    <div class="gallery21_arrow-icon"><svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.31066 8.75001L9.03033 14.4697L7.96967 15.5303L0.439339 8.00001L7.96967 0.469676L9.03033 1.53034L3.31066 7.25001L15.5 7.25L15.5 8.75L3.31066 8.75001Z" fill="currentColor"></path></svg></div>
                  </div>
                  <div class="gallery21_arrow swiper-button-next" aria-label="Next slide">
                    <div class="gallery21_arrow-icon"><svg width="100%" height="100%" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.6893 7.25L6.96967 1.53033L8.03033 0.469666L15.5607 8L8.03033 15.5303L6.96967 14.4697L12.6893 8.75H0.5V7.25H12.6893Z" fill="currentColor"></path></svg></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAMILIES -->
      <section class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="padding-section-large">
              <div class="layout_component">
                <div class="layout_content">
                  <div class="margin-bottom margin-small"><h3>We think of <span class="text-highlight">families</span> with children</h3></div>
                  <div class="margin-bottom margin-small"><img src="/images/647321a78126600a5a05bde0_flower.svg" loading="lazy" alt="" class="flower-divider" /></div>
                  <div class="margin-bottom margin-small"><p class="text-size-medium">The entire cottage is set up for a comfortable stay for families with children, making it your perfect base for a carefree holiday. You will have access to a changing table, board games, books, sports equipment and much more.</p></div>
                  <div class="margin-top margin-medium">
                    <div class="button-group"><a href="#reservation" class="button">Book now</a></div>
                  </div>
                </div>
                <div class="layout_image-wrapper">
                  <img src="/images/64fec541385f1e55d5bdf3e7_Sejkora_obyvaci_pokoj_1_Large.webp" loading="lazy" alt="Living room" class="layout_image" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- BARN -->
      <section class="section background-color-darkgreen">
        <div class="padding-global">
          <div class="container-large">
            <div class="layout_component">
              <div class="layout_image-wrapper">
                <img src="/images/64fecc2a2994b2723a1efd2f_Sejkora_posezeni_ve_stodole_1_Large.webp" loading="lazy" alt="Barn" class="layout_image" />
              </div>
              <div class="layout_content">
                <div class="margin-bottom margin-small"><div class="max-width-small"><h3>A <span class="text-highlight">unique</span> blend of relaxation and outdoor fun</h3></div></div>
                <div class="margin-bottom margin-small"><img src="/images/647321a78126600a5a05bde0_flower.svg" loading="lazy" alt="" class="flower-divider" /></div>
                <div class="margin-bottom margin-small"><p class="text-size-medium">Enjoy perfect relaxation in our recreation barn with a Finnish sauna, outdoor seating, BBQ grill, and fun at the ping-pong table and table football.</p></div>
                <div class="margin-top margin-medium">
                  <div class="button-group"><a href="#reservation" class="button">Book now</a></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SURROUNDINGS -->
