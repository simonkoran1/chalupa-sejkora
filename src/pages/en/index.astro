const surroundingsImages = [
  { url: "/images/646e676880c678ba21ea6857_image-crop-200001022.webp", caption: "Paseky nad Jizerou", distance: "6.5 KM • 8 MIN. BY CAR" },
  { url: "/images/6476f280b2510bb26a3ef2aa_Rokytnice-nad-Jizerou.webp", caption: "Rokytnice nad Jizerou", distance: "8.4 KM • 10 MIN. BY CAR" },
  { url: "/images/6485e70de8b0f28bdcb9bf9e_2022-08-14.webp", caption: "Bozkov Dolomite Caves", distance: "10.1 KM • 13 MIN. BY CAR" },
