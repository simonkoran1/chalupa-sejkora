  { url: "/images/64fec5c2385f1e55d5be7bf0_Sejkora_obyvaci_pokoj_2_Large.webp", caption: "Living room", label: "Living room" },
  { url: "/images/64fec62c880af21199abfd0f_Sejkora_loznice_1_1_Large.webp", caption: "Bedroom 1", label: "Bedroom 1" },
