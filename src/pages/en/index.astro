  { url: "/images/64fecaca9f7f964880182ab1_Sejkora_kuchyne_2_Large.webp", caption: "Kitchen", label: "Kitchen" },
  { url: "/images/64fecafd126548ca6e8921ec_Sejkora_koupelna_2_Large.webp", caption: "Bathroom 1", label: "Bathroom 1" },
  { url: "/images/64fecb17b78725a05b18c774_Sejkora_koupelna_2_1_Large.webp", caption: "Bathroom 1", label: "Bathroom 1" },
  { url: "/images/64fecb3aaef6acf8a9ece446_Sejkora_koupelna_1_Large.webp", caption: "Bathroom 2", label: "Bathroom 2" },
  { url: "/images/64fecb9ee214f2e762e44a71_Sejkora_detske_hriste_s_piskovistem_1_Large.webp", caption: "Children's playground", label: "Children's playground" },
  { url: "/images/64fecbbf71b5f82b71dd7f12_Sejkora_detske_hriste_s_piskovistem_2_Large.webp", caption: "Children's playground", label: "Children's playground" },
  { url: "/images/6502b5e1f91f4d27cd395c7b_AAA_zahrada_3_Large.webp", caption: "Garden", label: "Garden" },
  { url: "/images/64fecc2a2994b2723a1efd2f_Sejkora_posezeni_ve_stodole_1_Large.webp", caption: "Barn seating", label: "Barn seating" },
  { url: "/images/64fecc4ef21d29c63f1f4590_Sejkora_herni_stodola_Large.webp", caption: "Games barn", label: "Games barn" },
  { url: "/images/64fecc91d2ee83c0e2f02c57_Sejkora_finska_sauna_Large.webp", caption: "Finnish sauna", label: "Finnish sauna" },
