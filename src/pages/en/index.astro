              </div>

              <div class="calendar-wrapper">
                <div class="w-form">
                  <form id="wf-form-Rezerva-n-formul" class="form-wrapper">
                    <input type="hidden" name="access_key" value="9763ef18-f282-4f78-a9ba-d96df5fe00e4" />
                    <input type="hidden" name="subject" value="New reservation – Chalupa Sejkora" />
                    <input type="hidden" name="from_name" value="Chalupa Sejkora" />
                    <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />
                    <div class="reservation-date-wrap">
                      <label for="date-range" class="field-label">Stay dates</label>
                      <input class="form-input flatpickr-range" name="Termin" placeholder="Check-in – Check-out" type="text" id="date-range" autocomplete="off" readonly />
                      <input type="hidden" name="Datum-prijezdu" id="check-in" />
                      <input type="hidden" name="Datum-odjezdu" id="check-out" />
                    </div>

                    <div>
                      <label for="Name" class="field-label">Name</label>
                      <input class="form-input" name="Jmeno" placeholder="Your name" type="text" id="Name" required />
                    </div>
                    <div>
                      <label for="Email" class="field-label">E-mail</label>
                      <input class="form-input" name="Email" placeholder="name@email.com" type="email" id="Email" required />
                    </div>
                    <div>
                      <label for="Phone" class="field-label">Phone</label>
                      <input class="form-input" name="Telefon" placeholder="+1" type="tel" id="Phone" required />
                    </div>
                    <div>
                      <label for="Notes" class="field-label">Notes</label>
                      <textarea id="Notes" name="Poznamka" placeholder="Any notes or special requests" class="form-input is-text-area"></textarea>
                    </div>
                    <button type="submit" class="button">Send</button>
                  </form>

                  <div class="success-message">
