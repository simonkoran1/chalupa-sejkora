---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
  canonicalPath?: string;
  alternateUrl?: string;
}

const {
  title,
  description = "Venkovská chalupa pro vaši jedinečnou dovolenou ve Vysokém nad Jizerou.",
  lang = "cs",
  canonicalPath,
  alternateUrl,
} = Astro.props;

const siteUrl = 'https://chalupasejkora.cz';
const pagePath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = `${siteUrl}${pagePath}`;
const ogLocale = lang === 'cs' ? 'cs_CZ' : 'en_US';
const ogImage = `${siteUrl}/images/647386d463040bdcf0d4e98f_og-chalupa-sejkora.jpg`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:site_name" content="Chalupa Sejkora" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- hreflang -->
  {alternateUrl && lang === 'cs' && <link rel="alternate" hreflang="en" href={`${siteUrl}${alternateUrl}`} />}
  {alternateUrl && lang === 'en' && <link rel="alternate" hreflang="cs" href={`${siteUrl}${alternateUrl}`} />}
  {alternateUrl && lang === 'cs' && <link rel="alternate" hreflang="cs" href={canonicalUrl} />}
  {alternateUrl && lang === 'en' && <link rel="alternate" hreflang="en" href={canonicalUrl} />}
  {alternateUrl && <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />}

  <meta name="robots" content="index, follow" />

  <link rel="icon" href="/images/6471bc9e651cee234dd91fbf_favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/images/6471bc4b651cee234dd8f4c6_webclip.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Playfair+Display:400,500,600,700,800,900" />
  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MLR0ED9RFN"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MLR0ED9RFN');
  </script>
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
  <style>html { scroll-behavior: smooth; }</style>
</head>
<body>
  <slot />
  <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/cs.js"></script>
  <script is:inline src="/scripts/main.js"></script>
</body>
</html>
