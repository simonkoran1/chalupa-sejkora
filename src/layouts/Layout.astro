---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { 
  title, 
  description = "Venkovská chalupa pro vaši jedinečnou dovolenou ve Vysokém nad Jizerou.",
  lang = "cs"
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/images/647386d463040bdcf0d4e98f_og-chalupa-sejkora.jpg" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" href="/images/6471bc9e651cee234dd91fbf_favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/images/6471bc4b651cee234dd8f4c6_webclip.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Playfair+Display:400,500,600,700,800,900" />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MLR0ED9RFN"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MLR0ED9RFN');
  </script>
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
  <style>html { scroll-behavior: smooth; }</style>
</head>
<body>
  <slot />
  <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/cs.js"></script>
  <script is:inline src="/scripts/main.js"></script>
</body>
</html>
